# === Bankroll & mode ===
INITIAL_BANKROLL_USDC=100
MODE=paper  # paper | live
FOCUS_VERTICAL=politics

# === Polymarket ===
POLYGON_RPC_URL=https://polygon-rpc.com
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# === LLM (Google Gemini 3) ===
# ANCHORED model names -- confirmed by user. Do not change.
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3-flash-preview
GEMINI_MODEL_SMART=gemini-3.1-pro-preview

# === News & social ===
NEWSAPI_KEY=
GDELT_ENABLED=true
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymoney/0.1

# === On-chain (whale tracker) ===
# Whale tracker uses Polymarket public data API (no key required).
# Alchemy is only needed if you later add direct Polygon event log streaming.
ALCHEMY_POLYGON_KEY=

# === Telegram bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Infra ===
DATABASE_URL=postgresql+psycopg://polymoney:polymoney@localhost:5432/polymoney
REDIS_URL=redis://localhost:6379/0

# === Risk limits ===
MAX_POSITION_PCT=0.05          # 5 percent of bankroll per trade max (aggressive since small bankroll)
MAX_EVENT_EXPOSURE_PCT=0.20
KELLY_FRACTION=0.33             # 1/3 Kelly
DAILY_DRAWDOWN_STOP_PCT=0.15    # pause 24h if we lose 15 percent in a day
MIN_EDGE_BPS=300                # need at least 3 percent edge to enter
MIN_CONFIDENCE=0.65

# === Dashboard ===
DASHBOARD_PORT=3000
API_PORT=8000
